# Server
PORT=3000
NODE_ENV=development

# Set to "true" only when running behind a trusted reverse proxy/load
# balancer (so req.ip reflects the real client IP for rate limiting/logging).
TRUST_PROXY=false

# Max requests per 15-minute window per IP for /register, /login,
# /refresh-token.
AUTH_RATE_LIMIT_MAX=20

# MongoDB
MONGODB_URI=

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
